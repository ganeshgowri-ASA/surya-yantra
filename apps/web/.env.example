# apps/web/.env.example
# Copy to apps/web/.env.local and fill in real values.
# DATABASE_URL and ANTHROPIC_API_KEY are required for hardware features.
# The seeded demo data works without them for UI exploration.

# --- Database ---
DATABASE_URL=postgres://user:pass@host/db?sslmode=require
DIRECT_URL=postgres://user:pass@host/db?sslmode=require

# --- Auth ---
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# --- AI ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...   # optional

# --- Hardware (production lab only) ---
ESL_SOLAR_HOST=192.168.1.40
MUX_DRIVER_URL=https://mux.srishti.local

# --- Antaryami-OS integration (optional) ---
ANTARYAMI_WEBHOOK_URL=https://antaryami.srishtipvlab.in/webhook
ANTARYAMI_HMAC_SECRET=replace-with-random-secret

# --- Observability ---
SENTRY_DSN=https://...@sentry.io/...
LOG_LEVEL=info